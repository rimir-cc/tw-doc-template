title: $:/plugins/rimir/doc-template/test/test-callout-custom
description: Test callout template with custom type and custom label override
type: text/vnd.tiddlywiki-multiple
tags: [[$:/tags/wiki-test-spec]]

title: $:/test/callout-template
type: text/vnd.tiddlywiki

\parameters (type:"info", label:"")
\whitespace trim
<$let
  calloutClass={{{ [[rr-callout rr-callout-]addsuffix<type>] }}}
  resolvedLabel={{{ [<label>!is[blank]] :else[<type>uppercase[]] }}}
>
<div class=<<calloutClass>>>
<div class="rr-callout-label"><$text text=<<resolvedLabel>>/></div>
<$slot $name="body">
//No callout content.//
</$slot>
</div>
</$let>
+
title: Output

\whitespace trim
<$transclude $tiddler="$:/test/callout-template" type="warning" label="Watch out">
<$fill $name="body">Important warning</$fill>
</$transclude>
+
title: ExpectedResult

<p><div class="rr-callout rr-callout-warning"><div class="rr-callout-label">Watch out</div>Important warning</div></p>
+
title: Narrative
