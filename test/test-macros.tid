title: DocTiddler
rdt.plugin-key: testplugin
rdt.plugin-name: test plugin
rdt.plugin-subtitle: A test plugin for unit testing

+
title: Output

\whitespace trim
\procedure rdt.plugin-card(title)
\whitespace trim
<$let cardPluginKey={{{ [<title>get[rdt.plugin-key]] }}} cardPluginTitle={{{ [[$:/plugins/rimir/]addsuffix<cardPluginKey>] }}}>
<$button class="tc-btn-invisible rdt-card" set="$:/state/rimir/doc-template/hub/selected" setTo=<<title>>>
<div class="rdt-card-title"><$text text={{{ [<title>get[rdt.plugin-name]] }}}/><span class="rdt-card-version">v<$text text={{{ [<cardPluginTitle>get[version]] }}}/></span></div>
<div class="rdt-card-desc"><$text text={{{ [<title>get[rdt.plugin-subtitle]] }}}/></div>
</$button>
</$let>
\end

<$transclude $variable="rdt.plugin-card" title="DocTiddler"/>
+
title: ExpectedResult

<p><button class="tc-btn-invisible rdt-card"><div class="rdt-card-title">test plugin<span class="rdt-card-version">v1.2.3</span></div><div class="rdt-card-desc">A test plugin for unit testing</div></button></p>
